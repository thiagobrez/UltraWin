// Committed, safe to publish — contains NO Team ID.
//
// This file is pulled in via Config/Build.xcconfig (referenced by project.yml).
// The real Apple Developer Team ID lives in Signing.local.xcconfig, which is
// gitignored and pulled in by the optional include below. The "?" makes the
// include optional, so the project still generates/builds without that file.
//
// Setup:
//   cp Config/Signing.local.xcconfig.example Config/Signing.local.xcconfig
//   # edit Config/Signing.local.xcconfig and set your DEVELOPMENT_TEAM
//   xcodegen generate
#include? "Signing.local.xcconfig"
